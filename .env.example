# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Remote server
REMOTE_HOST=your-vps-ip-or-hostname
REMOTE_USER=root
SSH_KEY=/home/youruser/.ssh/your_key

# TURN server credentials
VITE_TURN_SERVER=turn.your-domain.com
VITE_TURN_USERNAME=your-turn-username
VITE_TURN_PASSWORD=your-turn-password

# Aggressive egress networks often require TURN over TLS on 443 only.
# Set to true to build the frontend with only turns:<server>:443?transport=tcp.
VITE_TURN_FORCE_TLS_443=false

# Optional explicit TURN URL override (comma-separated). Leave empty unless you
# need a custom ordering or a single 443/TLS path.
# Example: VITE_TURN_URLS=turns:turn.your-domain.com:443?transport=tcp
VITE_TURN_URLS=

# Allowed WebSocket origins (comma-separated)
CORS_ORIGIN=https://your-domain.com

# Optional bulletin storage/runtime overrides
BULLETIN_STORE_PATH=/var/lib/messenger-backend/bulletins.json
BULLETIN_TTL_MINUTES=4320
